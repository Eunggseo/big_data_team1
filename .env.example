OPENAI_API_KEY=your_openai_key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Local path to the MIMIC-IV discharge notes CSV.
DATA_PATH=/path/to/discharge.csv

# Local storage paths used by the app.
FAISS_INDEX_DIR=./storage/faiss_index
CACHE_DB_PATH=./storage/cache.sqlite

# Optional if your team loads data from AWS using explicit credentials.
# Prefer IAM roles or AWS CLI profiles when available.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
